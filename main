local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local Window = Rayfield:CreateWindow({
    Name = "Fight on a Baseplate",
    ScriptID = "sid_mzso9v2drojs",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "by shrak",
    ConfigurationSaving = { Enabled = false },
    KeySystem = false
})

-- English Tab
local EnglishTab = Window:CreateTab("English", 0)
EnglishTab:CreateParagraph({
    Title = "Info",
    Content = "This script is currently patched due to recent game changes, but a fixed version is already being worked on and will be back up soon. It stays completely free and keyless - no keys, no payments, ever. For real-time updates on when script is back up join our Discord server."
})
EnglishTab:CreateButton({
    Name = "Copy Discord Link",
    Callback = function()
        setclipboard("https://discord.gg/hEbP6rWKy2")
        Rayfield:Notify({ Title = "Copied", Content = "Discord link copied to clipboard.", Duration = 3 })
    end
})

-- Spanish Tab
local SpanishTab = Window:CreateTab("Spanish", 0)
SpanishTab:CreateParagraph({
    Title = "Info",
    Content = "Este script está actualmente parcheado debido a cambios recientes en el juego, pero ya se está trabajando en una versión corregida y volverá a estar disponible pronto. Sigue siendo completamente gratuito y sin claves - sin claves, sin pagos, nunca. Para actualizaciones en tiempo real sobre cuándo vuelve a estar disponible, únete a nuestro servidor de Discord."
})
SpanishTab:CreateButton({
    Name = "Copiar enlace de Discord",
    Callback = function()
        setclipboard("https://discord.gg/hEbP6rWKy2")
        Rayfield:Notify({ Title = "Copiado", Content = "Enlace de Discord copiado al portapapeles.", Duration = 3 })
    end
})

